{
  "luci-app-client-monitor": {
    "description": "Grant read access to local client status",
    "read": {
      "file": [ "/etc/luci-client-monitor-notes.json" ],
      "ubus": {
        "luci": [ "getARPTable", "getDHCPLeases", "getDHCPv6Leases", "getHostHints" ],
        "network.wireless": [ "status" ]
      }
    },
    "write": {
      "file": [ "/etc/luci-client-monitor-notes.json" ]
    }
  }
}
